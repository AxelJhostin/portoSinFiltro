PORT=4000

# Conseguir en: Supabase > Project Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service_role-key   # ⚠️ NUNCA exponer al frontend

# JWT secret de Supabase (para verificar tokens del frontend)
# Supabase > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173
