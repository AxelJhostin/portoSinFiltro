PORT=4000

# Conseguir en: Supabase > Project Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co

# Supabase > Project Settings > API Keys > secret
SUPABASE_SERVICE_KEY=tu-secret-key   # ⚠️ NUNCA exponer al frontend

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# NOTA: la verificación de tokens usa el JWKS de Supabase (ES256),
# por lo que NO se necesita SUPABASE_JWT_SECRET.
